{% doc %}
  @prompt
    Create a button group section that displays multiple buttons side by side. It should support at least 2 buttons, each with a customizable label and link. The buttons should be styled to match the theme's existing button styles, be horizontally aligned, and be responsive (stacking vertically on mobile). Include settings for button style (primary/secondary) per button.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-button-group-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-button-group__container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.button_spacing }}px;
    justify-content: {{ block.settings.alignment }};
    align-items: center;
    flex-wrap: wrap;
  }

  .ai-button-group__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    font-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    text-decoration: none;
    border-radius: {{ settings.radius_large }}px;
    transition: all 0.2s ease;
    cursor: pointer;
    border: 2px solid transparent;
    white-space: nowrap;
  }

  .ai-button-group__button--primary-{{ ai_gen_id }} {
    background-color: {{ block.settings.primary_bg_color }};
    color: {{ block.settings.primary_text_color }};
    border-color: {{ block.settings.primary_bg_color }};
  }

  .ai-button-group__button--primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.primary_hover_bg_color }};
    border-color: {{ block.settings.primary_hover_bg_color }};
    color: {{ block.settings.primary_hover_text_color }};
  }

  .ai-button-group__button--secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.secondary_bg_color }};
    color: {{ block.settings.secondary_text_color }};
    border-color: {{ block.settings.secondary_border_color }};
  }

  .ai-button-group__button--secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.secondary_hover_bg_color }};
    border-color: {{ block.settings.secondary_hover_border_color }};
    color: {{ block.settings.secondary_hover_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-button-group__container-{{ ai_gen_id }} {
      flex-direction: {{ block.settings.mobile_layout }};
      gap: {{ block.settings.mobile_button_spacing }}px;
    }

    .ai-button-group__button-{{ ai_gen_id }} {
      {% if block.settings.mobile_layout == 'column' %}
        width: 100%;
      {% endif %}
    }
  }
{% endstyle %}

<button-group-{{ ai_gen_id }}
  class="ai-button-group-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-button-group__container-{{ ai_gen_id }}">
    {% if block.settings.button_1_label != blank %}
      <a
        href="{{ block.settings.button_1_link }}"
        class="ai-button-group__button-{{ ai_gen_id }} ai-button-group__button--{{ block.settings.button_1_style }}-{{ ai_gen_id }}"
      >
        {{ block.settings.button_1_label }}
      </a>
    {% endif %}

    {% if block.settings.button_2_label != blank %}
      <a
        href="{{ block.settings.button_2_link }}"
        class="ai-button-group__button-{{ ai_gen_id }} ai-button-group__button--{{ block.settings.button_2_style }}-{{ ai_gen_id }}"
      >
        {{ block.settings.button_2_label }}
      </a>
    {% endif %}

    {% if block.settings.button_3_label != blank %}
      <a
        href="{{ block.settings.button_3_link }}"
        class="ai-button-group__button-{{ ai_gen_id }} ai-button-group__button--{{ block.settings.button_3_style }}-{{ ai_gen_id }}"
      >
        {{ block.settings.button_3_label }}
      </a>
    {% endif %}

    {% if block.settings.button_4_label != blank %}
      <a
        href="{{ block.settings.button_4_link }}"
        class="ai-button-group__button-{{ ai_gen_id }} ai-button-group__button--{{ block.settings.button_4_style }}-{{ ai_gen_id }}"
      >
        {{ block.settings.button_4_label }}
      </a>
    {% endif %}
  </div>
</button-group-{{ ai_gen_id }}>

<script>
  (function() {
    class ButtonGroup{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.buttons = this.querySelectorAll('.ai-button-group__button-{{ ai_gen_id }}');
      }
    }

    customElements.define('button-group-{{ ai_gen_id }}', ButtonGroup{{ ai_gen_id }});
  })();
</script>

