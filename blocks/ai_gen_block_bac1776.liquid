    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#F4EFE6"
    },
    {
      "type": "color",
      "id": "tagline_color",
      "label": "Tagline",
      "default": "#C6FF3D"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body text",
      "default": "#F4EFE6"
    },
    {
      "type": "color",
      "id": "muted_text_color",
