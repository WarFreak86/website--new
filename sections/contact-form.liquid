<section
  class="section-shell contact-support"
  style="
    --contact-bg: {{ section.settings.background_color }};
    --contact-text: {{ section.settings.text_color }};
    --contact-muted: {{ section.settings.muted_text_color }};
    --contact-border: {{ section.settings.border_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="page-width">
    <div class="contact-support__grid">
      <div class="contact-support__content">
        <h1 class="section-title contact-support__title">{{ section.settings.heading | escape }}</h1>
        {%- if section.settings.intro != blank -%}
          <div class="rte contact-support__intro">{{ section.settings.intro }}</div>
        {%- endif -%}

        <div class="contact-support__notes" aria-label="Support details">
          <article class="contact-support__note">
            <h2>{{ section.settings.order_heading | escape }}</h2>
            <p>{{ section.settings.order_text | escape }}</p>
          </article>
          <article class="contact-support__note">
            <h2>{{ section.settings.damage_heading | escape }}</h2>
            <p>{{ section.settings.damage_text | escape }}</p>
          </article>
          <article class="contact-support__note">
            <h2>{{ section.settings.collab_heading | escape }}</h2>
            <p>{{ section.settings.collab_text | escape }}</p>
          </article>
        </div>
      </div>

      <div class="contact-support__form-panel">
        {% form 'contact', class: 'contact-form' %}
          {% if form.posted_successfully? %}
            <p class="form-success" tabindex="-1">Your message has been sent.</p>
          {% endif %}
          {% if form.errors %}
            <div class="form-error">{{ form.errors | default_errors }}</div>
          {% endif %}

          <label for="ContactName-{{ section.id }}">Name</label>
          <input id="ContactName-{{ section.id }}" type="text" name="contact[name]" value="{{ form.name }}" autocomplete="name" required>

          <label for="ContactEmail-{{ section.id }}">Email</label>
          <input id="ContactEmail-{{ section.id }}" type="email" name="contact[email]" value="{{ form.email }}" autocomplete="email" required>

          <label for="ContactOrder-{{ section.id }}">Order number</label>
          <input id="ContactOrder-{{ section.id }}" type="text" name="contact[order_number]" autocomplete="off">

          <label for="ContactInquiryType-{{ section.id }}">Inquiry type</label>
          <select id="ContactInquiryType-{{ section.id }}" name="contact[inquiry_type]" required>
            <option value="Order question">Order question</option>
            <option value="Damaged shipment">Damaged shipment</option>
            <option value="Production / shipping timing">Production / shipping timing</option>
            <option value="Collector release inquiry">Collector release inquiry</option>
            <option value="Custom / collaboration request">Custom / collaboration request</option>
            <option value="General question">General question</option>
          </select>

          <label for="ContactBody-{{ section.id }}">Message</label>
          <textarea id="ContactBody-{{ section.id }}" name="contact[body]" rows="7" required>{{ form.body }}</textarea>

          <button class="btn btn-primary" type="submit">Send Message</button>
        {% endform %}
      </div>
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .contact-support {
    background: var(--contact-bg, #101113);
    color: var(--contact-text, #F4EFE6);
  }

  #shopify-section-{{ section.id }} .contact-support__grid {
    display: grid;
    gap: clamp(1.4rem, 4vw, 3rem);
    align-items: start;
  }

  #shopify-section-{{ section.id }} .contact-support__title {
    margin-bottom: 1rem;
  }

  #shopify-section-{{ section.id }} .contact-support__intro {
    max-width: 62ch;
    color: var(--contact-muted, #A7A29A);
  }

  #shopify-section-{{ section.id }} .contact-support__notes {
    display: grid;
    gap: 0.85rem;
    margin-top: 1.4rem;
  }

  #shopify-section-{{ section.id }} .contact-support__note {
    border-left: 2px solid var(--contact-border, #2A2B2F);
    padding-left: 1rem;
  }

  #shopify-section-{{ section.id }} .contact-support__note h2 {
    margin: 0 0 0.35rem;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  #shopify-section-{{ section.id }} .contact-support__note p {
    margin: 0;
    color: var(--contact-muted, #A7A29A);
  }

  #shopify-section-{{ section.id }} .contact-support__form-panel {
    border: 1px solid var(--contact-border, #2A2B2F);
    background: color-mix(in srgb, var(--contact-bg, #101113) 78%, black 22%);
    border-radius: var(--ds-radius-md, 0.3rem);
    padding: clamp(1rem, 3vw, 1.5rem);
  }

  #shopify-section-{{ section.id }} .contact-form {
    display: grid;
    gap: 0.8rem;
  }

  #shopify-section-{{ section.id }} .contact-form label {
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--contact-muted, #A7A29A);
  }

  #shopify-section-{{ section.id }} .contact-form input,
  #shopify-section-{{ section.id }} .contact-form select,
  #shopify-section-{{ section.id }} .contact-form textarea {
    width: 100%;
  }

  #shopify-section-{{ section.id }} .contact-form .btn {
    margin-top: 0.4rem;
  }

  @media (min-width: 900px) {
    #shopify-section-{{ section.id }} .contact-support__grid {
      grid-template-columns: minmax(0, 0.95fr) minmax(24rem, 0.8fr);
    }
  }
</style>

{% schema %}
{
  "name": "Contact form",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Contact Render-Lab" },
    { "type": "richtext", "id": "intro", "label": "Intro", "default": "<p>Questions about an order, damaged shipment, production timing, collector releases, or custom work? Send a message below and include your order number if you have one.</p>" },
    { "type": "text", "id": "order_heading", "label": "Order heading", "default": "Order Questions" },
    { "type": "text", "id": "order_text", "label": "Order text", "default": "For questions about an existing order, include your order number and the email used at checkout." },
    { "type": "text", "id": "damage_heading", "label": "Damage heading", "default": "Damaged Shipment" },
    { "type": "text", "id": "damage_text", "label": "Damage text", "default": "If your print arrives damaged, contact us with clear photos of the packaging and product so we can review the issue quickly." },
    { "type": "text", "id": "collab_heading", "label": "Inquiry heading", "default": "Collector / Collaboration Inquiries" },
    { "type": "text", "id": "collab_text", "label": "Inquiry text", "default": "For limited releases, custom projects, or brand collaborations, send a short description of what you are looking for." },
    { "type": "color", "id": "background_color", "label": "Section background", "default": "#101113" },
    { "type": "color", "id": "text_color", "label": "Section text color", "default": "#F4EFE6" },
    { "type": "color", "id": "muted_text_color", "label": "Muted text color", "default": "#A7A29A" },
    { "type": "color", "id": "border_color", "label": "Border color", "default": "#2A2B2F" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "default": 64, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "default": 64, "unit": "px" }
  ],
  "presets": [{ "name": "Contact form" }]
}
{% endschema %}
