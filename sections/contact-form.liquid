<section class="section-shell" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; background: {{ section.settings.background_color }}; color: {{ section.settings.text_color }};">
  <div class="page-width" style="text-align: {{ section.settings.text_alignment }};">
    <h2 class="section-title">{{ section.settings.heading }}</h2>
    {% form 'contact', class: 'contact-form' %}
      {% if form.posted_successfully? %}<p class='form-success'>Your message has been sent.</p>{% endif %}
      {% if form.errors %}<div class='form-error'>{{ form.errors | default_errors }}</div>{% endif %}
      <label for="ContactName-{{ section.id }}">Name</label>
      <input id="ContactName-{{ section.id }}" type="text" name="contact[name]" value="{{ form.name }}">
      <label for="ContactEmail-{{ section.id }}">Email</label>
      <input id="ContactEmail-{{ section.id }}" type="email" name="contact[email]" value="{{ form.email }}" required>
      <label for="ContactBody-{{ section.id }}">Message</label>
      <textarea id="ContactBody-{{ section.id }}" name="contact[body]" rows="6">{{ form.body }}</textarea>
      <button class="btn btn-primary" type="submit">Send</button>
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Contact form",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Contact us" },
    { "type": "select", "id": "text_alignment", "label": "Text alignment", "default": "left", "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"}] },
    { "type": "color", "id": "background_color", "label": "Section background", "default": "#101113" },
    { "type": "color", "id": "text_color", "label": "Section text color", "default": "#F4EFE6" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "default": 64, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "default": 64, "unit": "px" }
  ],
  "presets": [{ "name": "Contact form" }]
}
{% endschema %}
