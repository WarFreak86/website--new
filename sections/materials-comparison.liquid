<section id="MaterialsComparison-{{ section.id }}" class="section-shell" style="--mc-pt: {{ section.settings.padding_top }}px; --mc-pb: {{ section.settings.padding_bottom }}px; --mc-bg: {{ section.settings.background_color }}; --mc-text: {{ section.settings.text_color }}; --mc-muted: {{ section.settings.muted_text_color }}; --mc-border: {{ section.settings.border_color }}; --mc-cols: {{ section.settings.columns_desktop }};">
  <div class="page-width">
    {%- if section.settings.eyebrow != blank -%}<p class="label-kicker reveal-fade-up" data-reveal="subtle">{{ section.settings.eyebrow | escape }}</p>{%- endif -%}
    <h2 class="section-title materials-comparison__title reveal-fade-up reveal-delay-1" data-reveal>{{ section.settings.heading | escape }}</h2>
    {%- if section.settings.intro != blank -%}<div class="materials-comparison__intro rte reveal-fade-up reveal-delay-2" data-reveal="subtle">{{ section.settings.intro }}</div>{%- endif -%}

    <div class="materials-comparison reveal-fade-up reveal-delay-3" data-reveal>
      {%- for block in section.blocks -%}
        <article class="materials-comparison__item value-card" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}<div class="materials-comparison__image image-hover-scale image-hover-scale--soft">{{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '320, 480, 720, 960, 1200', sizes: '(min-width: 990px) 30vw, 100vw', alt: block.settings.heading }}</div>{%- endif -%}
          <h3>{{ block.settings.heading | escape }}</h3>
          <div class="rte">{{ block.settings.text }}</div>
          {%- if block.settings.spec_1 != blank -%}<p class="materials-comparison__spec"><strong>{{ block.settings.spec_1_label | default: 'Finish' | escape }}:</strong> {{ block.settings.spec_1 | escape }}</p>{%- endif -%}
          {%- if block.settings.spec_2 != blank -%}<p class="materials-comparison__spec"><strong>{{ block.settings.spec_2_label | default: 'Durability' | escape }}:</strong> {{ block.settings.spec_2 | escape }}</p>{%- endif -%}
        </article>
      {%- endfor -%}
    </div>

    {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}<p class="materials-comparison__actions reveal-fade-up" data-reveal><a class="btn-premium" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label | escape }}</a></p>{%- endif -%}
  </div>
</section>

<style>
  #MaterialsComparison-{{ section.id }} { padding-top: var(--mc-pt); padding-bottom: var(--mc-pb); background: var(--mc-bg, var(--ds-color-bg, #050505)); }
  #MaterialsComparison-{{ section.id }} .materials-comparison__title { text-align: left; color: var(--mc-text, var(--ds-color-text-strong, #F4EFE6)); }
  #MaterialsComparison-{{ section.id }} .materials-comparison__intro { max-width: 58ch; margin-bottom: 1rem; color: var(--mc-muted, var(--ds-color-text-muted, #A7A29A)); }
  #MaterialsComparison-{{ section.id }} .materials-comparison { display: grid; grid-template-columns: repeat(var(--mc-cols), minmax(0, 1fr)); gap: 0.9rem; }
  #MaterialsComparison-{{ section.id }} .materials-comparison__item { border-color: var(--mc-border, var(--ds-color-border, #2A2B2F)); }
  #MaterialsComparison-{{ section.id }} .materials-comparison__image { margin: -0.3rem -0.3rem 0.7rem; border: 1px solid var(--mc-border, var(--ds-color-border, #2A2B2F)); border-radius: var(--ds-radius-md, 0.2rem); overflow: hidden; }
  #MaterialsComparison-{{ section.id }} .materials-comparison__item h3 { margin: 0 0 0.45rem; text-transform: uppercase; font-family: var(--ds-font-heading, var(--font-heading)); color: var(--mc-text, var(--ds-color-text-strong, #F4EFE6)); }
  #MaterialsComparison-{{ section.id }} .materials-comparison__item .rte { color: var(--mc-muted, var(--ds-color-text, #F4EFE6)); }
  #MaterialsComparison-{{ section.id }} .materials-comparison__spec { margin: 0.35rem 0 0; color: var(--mc-muted, var(--ds-color-text-muted, #A7A29A)); }
  #MaterialsComparison-{{ section.id }} .materials-comparison__actions { margin-top: 1rem; }
  @media (max-width: 989px) { #MaterialsComparison-{{ section.id }} .materials-comparison { grid-template-columns: 1fr; } }
</style>

{% schema %}
{
  "name": "Materials comparison",
  "max_blocks": 6,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Material Education" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Materials Comparison" },
    { "type": "richtext", "id": "intro", "label": "Intro", "default": "<p>Compare substrate options with collector-focused quality notes.</p>" },
    { "type": "text", "id": "cta_label", "label": "CTA label" },
    { "type": "url", "id": "cta_link", "label": "CTA link" },
    { "type": "select", "id": "columns_desktop", "label": "Desktop columns", "default": "3", "options": [{"value":"2","label":"2"},{"value":"3","label":"3"}] },
    { "type": "color", "id": "background_color", "label": "Section background", "default": "#050505" },
    { "type": "color", "id": "text_color", "label": "Heading color", "default": "#F4EFE6" },
    { "type": "color", "id": "muted_text_color", "label": "Body color", "default": "#A7A29A" },
    { "type": "color", "id": "border_color", "label": "Border color", "default": "#2A2B2F" },
    { "type": "range", "id": "padding_top", "label": "Top spacing", "min": 0, "max": 180, "step": 4, "default": 56, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Bottom spacing", "min": 0, "max": 180, "step": 4, "default": 56, "unit": "px" }
  ],
  "blocks": [
    {
      "type": "material",
      "name": "Material column",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Optional image" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Render-Lab Standard" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Collector-focused durability, clarity, and finish consistency.</p>" },
        { "type": "text", "id": "spec_1_label", "label": "Spec 1 label", "default": "Finish" },
        { "type": "text", "id": "spec_1", "label": "Spec 1 value", "default": "Museum-grade matte" },
        { "type": "text", "id": "spec_2_label", "label": "Spec 2 label", "default": "Durability" },
        { "type": "text", "id": "spec_2", "label": "Spec 2 value", "default": "Archival-resistant coating" }
      ]
    }
  ],
  "presets": [{ "name": "Materials comparison" }]
}
{% endschema %}
