{%- if section.settings.text != blank -%}
  <div class="announcement-bar" role="region" aria-label="Announcement">
    <div class="page-width announcement-bar__inner">
      <span>{{ section.settings.text | escape }}</span>
      {%- if section.settings.link_label != blank and section.settings.link != blank -%}
        <a href="{{ section.settings.link }}"><strong>{{ section.settings.link_label | escape }}</strong></a>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "tag": "section",
  "class": "section-announcement-bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Free shipping on all orders over $75"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    }
  ]
}
{% endschema %}
