<section class="section-shell">
  <div class="page-width" style="text-align:center; max-width:700px;">
    {%- if section.settings.logo != blank -%}
      <p>{{ section.settings.logo | image_url: width: 220 | image_tag: alt: shop.name }}</p>
    {%- endif -%}
    <h1 class="section-title">{{ section.settings.heading | escape }}</h1>
    <p>{{ section.settings.subtext | escape }}</p>
    {% form 'storefront_password', class: 'password-form' %}
      {%- if form.errors -%}<div class="form-error">{{ form.errors | default_errors }}</div>{%- endif -%}
      <label for="PasswordInput-{{ section.id }}">Password</label>
      <input id="PasswordInput-{{ section.id }}" type="password" name="password" required>
      <button class="btn btn-primary" type="submit">Enter store</button>
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Main password",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Opening soon" },
    { "type": "text", "id": "subtext", "label": "Subtext", "default": "This store is currently password protected." }
  ]
}
{% endschema %}
