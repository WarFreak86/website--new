<section class="section-shell" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; background: {{ section.settings.background_color }}; color: {{ section.settings.text_color }};">
  <div class="page-width" style="text-align: {{ section.settings.text_alignment }};">
    <h2 class="section-title">{{ section.settings.heading | escape }}</h2>
    {%- for block in section.blocks -%}
      <details class="value-card" {{ block.shopify_attributes }}>
        <summary><strong>{{ block.settings.question | escape }}</strong></summary>
        <div class="rte">{{ block.settings.answer }}</div>
      </details>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "max_blocks": 12,
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "FAQ" },
    { "type": "select", "id": "text_alignment", "label": "Text alignment", "default": "left", "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"}] },
    { "type": "color", "id": "background_color", "label": "Section background", "default": "#101113" },
    { "type": "color", "id": "text_color", "label": "Section text color", "default": "#F4EFE6" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "default": 64, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "default": 64, "unit": "px" }
  ],
  "blocks": [
    {
      "type": "qa",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "How does mounting work?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Use the included magnet system for tool-free mounting.</p>" }
      ]
    }
  ],
  "presets": [{ "name": "FAQ" }]
}
{% endschema %}
