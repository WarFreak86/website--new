<section
  id="LoreManifesto-{{ section.id }}"
  class="section-shell"
  style="
    --lmt-pt: {{ section.settings.padding_top }}px;
    --lmt-pb: {{ section.settings.padding_bottom }}px;
    --lmt-bg: {{ section.settings.background_color }};
    --lmt-text: {{ section.settings.text_color }};
    --lmt-muted: {{ section.settings.muted_text_color }};
    --lmt-border: {{ section.settings.border_color }};
  "
>
  <div class="page-width editorial-container">
    <div class="lore-manifesto-block reveal-fade-up" data-reveal="deep">
      {%- if section.settings.eyebrow != blank -%}<p class="label-kicker reveal-fade-up reveal-delay-1" data-reveal="subtle">{{ section.settings.eyebrow | escape }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="section-title lore-manifesto-block__title reveal-fade-up reveal-delay-2" data-reveal>{{ section.settings.heading | escape }}</h2>{%- endif -%}
      <div class="lore-manifesto rte reveal-fade-up reveal-delay-3" data-reveal="subtle">{{ section.settings.text }}</div>
      {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}<p class="reveal-fade-up reveal-delay-4" data-reveal="subtle"><a class="btn-premium" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label | escape }}</a></p>{%- endif -%}
    </div>
  </div>
</section>

<style>
  #LoreManifesto-{{ section.id }} { padding-top: var(--lmt-pt); padding-bottom: var(--lmt-pb); background: var(--lmt-bg, var(--ds-color-bg, #050505)); }
  #LoreManifesto-{{ section.id }} .lore-manifesto-block { border: 1px solid var(--lmt-border, var(--ds-color-border, #2A2B2F)); border-radius: var(--ds-radius-lg, 0.4rem); padding: clamp(1rem, 3vw, 2.2rem); background: linear-gradient(180deg, var(--ds-color-surface-1, #17181B) 0%, var(--ds-color-surface-0, #101113) 100%); }
  #LoreManifesto-{{ section.id }} .lore-manifesto-block__title { text-align: left; margin-bottom: 0.8rem; color: var(--lmt-text, var(--ds-color-text-strong, #F4EFE6)); }
  #LoreManifesto-{{ section.id }} .lore-manifesto { max-width: 70ch; font-size: clamp(1.02rem, 1.7vw, 1.22rem); line-height: 1.75; color: var(--lmt-muted, var(--ds-color-text, #F4EFE6)); }
</style>

{% schema %}
{
  "name": "Lore manifesto",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Manifesto" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Digital Relics For Unquiet Rooms" },
    { "type": "richtext", "id": "text", "label": "Body text", "default": "<p>Render-Lab creates visual artifacts inspired by street culture, synthetic worlds, cinematic decay, and the tension between beauty and chaos.</p>" },
    { "type": "text", "id": "cta_label", "label": "CTA label" },
    { "type": "url", "id": "cta_link", "label": "CTA link" },
    { "type": "color", "id": "background_color", "label": "Section background", "default": "#050505" },
    { "type": "color", "id": "text_color", "label": "Heading color", "default": "#F4EFE6" },
    { "type": "color", "id": "muted_text_color", "label": "Body color", "default": "#A7A29A" },
    { "type": "color", "id": "border_color", "label": "Border color", "default": "#2A2B2F" },
    { "type": "range", "id": "padding_top", "label": "Top spacing", "min": 0, "max": 180, "step": 4, "default": 56, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Bottom spacing", "min": 0, "max": 180, "step": 4, "default": 56, "unit": "px" }
  ],
  "presets": [{ "name": "Lore manifesto" }]
}
{% endschema %}
