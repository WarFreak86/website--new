<section id="LimitedDropInfo-{{ section.id }}" class="section-shell" style="--ldi-pt: {{ section.settings.padding_top }}px; --ldi-pb: {{ section.settings.padding_bottom }}px; --ldi-bg: {{ section.settings.background_color }}; --ldi-text: {{ section.settings.text_color }}; --ldi-muted: {{ section.settings.muted_text_color }}; --ldi-border: {{ section.settings.border_color }};">
  <div class="page-width">
    <div class="limited-drop-info overlay-atmospheric reveal-fade-up" data-reveal="deep">
      <div class="limited-drop-info__header">
        <p class="label-kicker reveal-fade-up reveal-delay-1" data-reveal="subtle">{{ section.settings.eyebrow | escape }}</p>
        <h2 class="section-title limited-drop-info__title reveal-fade-up reveal-delay-2" data-reveal>{{ section.settings.heading | escape }}</h2>
      </div>

      {%- if section.settings.image != blank -%}
        <div class="limited-drop-info__image image-hover-scale image-hover-scale--soft reveal-fade-up reveal-delay-2" data-reveal="subtle">
          {{ section.settings.image | image_url: width: 1800 | image_tag: loading: 'lazy', widths: '720, 960, 1280, 1600, 1800', sizes: '100vw', alt: section.settings.heading }}
        </div>
      {%- endif -%}

      <div class="limited-drop-info__body rte reveal-fade-up reveal-delay-3" data-reveal="subtle">{{ section.settings.text }}</div>

      <div class="limited-drop-info__meta reveal-fade-up reveal-delay-4" data-reveal="subtle">
        {%- if section.settings.release_window != blank -%}<p><strong>{{ section.settings.release_window_label | default: 'Release Window' | escape }}:</strong> {{ section.settings.release_window | escape }}</p>{%- endif -%}
        {%- if section.settings.edition_note != blank -%}<p><strong>{{ section.settings.edition_note_label | default: 'Edition Note' | escape }}:</strong> {{ section.settings.edition_note | escape }}</p>{%- endif -%}
      </div>

      {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
        <p class="limited-drop-info__actions reveal-fade-up" data-reveal><a class="btn-premium" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label | escape }}</a></p>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  #LimitedDropInfo-{{ section.id }} { padding-top: var(--ldi-pt); padding-bottom: var(--ldi-pb); background: var(--ldi-bg, var(--ds-color-bg, #050505)); }
  #LimitedDropInfo-{{ section.id }} .limited-drop-info { position: relative; overflow: hidden; border: 1px solid var(--ldi-border, var(--ds-color-border, #2A2B2F)); border-radius: var(--ds-radius-lg, 0.4rem); padding: clamp(1rem, 2.8vw, 2rem); background: linear-gradient(180deg, var(--ds-color-surface-1, #17181B) 0%, var(--ds-color-surface-0, #101113) 100%); }
  #LimitedDropInfo-{{ section.id }} .limited-drop-info__title { text-align: left; margin-bottom: 0.7rem; color: var(--ldi-text, var(--ds-color-text-strong, #F4EFE6)); }
  #LimitedDropInfo-{{ section.id }} .limited-drop-info__image { margin: 0 0 0.9rem; border: 1px solid var(--ldi-border, var(--ds-color-border, #2A2B2F)); border-radius: var(--ds-radius-md, 0.2rem); overflow: hidden; }
  #LimitedDropInfo-{{ section.id }} .limited-drop-info__body { max-width: 56ch; margin-bottom: 0.8rem; color: var(--ldi-muted, var(--ds-color-text, #F4EFE6)); }
  #LimitedDropInfo-{{ section.id }} .limited-drop-info__meta { display: grid; gap: 0.35rem; color: var(--ldi-muted, var(--ds-color-text-muted, #A7A29A)); }
  #LimitedDropInfo-{{ section.id }} .limited-drop-info__meta p { margin: 0; }
  #LimitedDropInfo-{{ section.id }} .limited-drop-info__actions { margin: 1rem 0 0; }
</style>

{% schema %}
{
  "name": "Limited drop info",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Drop Bulletin" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Limited Edition Release" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>This release is curated for collectors and produced in restricted circulation.</p>" },
    { "type": "image_picker", "id": "image", "label": "Optional image" },
    { "type": "text", "id": "release_window_label", "label": "Release window label", "default": "Release Window" },
    { "type": "text", "id": "release_window", "label": "Release window", "default": "48-hour release window" },
    { "type": "text", "id": "edition_note_label", "label": "Edition note label", "default": "Edition Note" },
    { "type": "text", "id": "edition_note", "label": "Edition note", "default": "Restock is not guaranteed once allocation is closed." },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Explore current drop" },
    { "type": "url", "id": "cta_link", "label": "CTA link" },
    { "type": "color", "id": "background_color", "label": "Section background", "default": "#050505" },
    { "type": "color", "id": "text_color", "label": "Heading color", "default": "#F4EFE6" },
    { "type": "color", "id": "muted_text_color", "label": "Body color", "default": "#A7A29A" },
    { "type": "color", "id": "border_color", "label": "Border color", "default": "#2A2B2F" },
    { "type": "range", "id": "padding_top", "label": "Top spacing", "min": 0, "max": 180, "step": 4, "default": 56, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Bottom spacing", "min": 0, "max": 180, "step": 4, "default": 56, "unit": "px" }
  ],
  "presets": [{ "name": "Limited drop info" }]
}
{% endschema %}
