<section id="CollectorTrustBar-{{ section.id }}" class="section-shell" style="--ctb-pt: {{ section.settings.padding_top }}px; --ctb-pb: {{ section.settings.padding_bottom }}px; --ctb-bg: {{ section.settings.background_color }}; --ctb-text: {{ section.settings.text_color }}; --ctb-muted: {{ section.settings.muted_text_color }}; --ctb-border: {{ section.settings.border_color }}; --ctb-cols: {{ section.settings.columns_desktop }};">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}<h2 class="section-title collector-trust-bar__title reveal-fade-up" data-reveal="deep">{{ section.settings.heading | escape }}</h2>{%- endif -%}
    {%- if section.settings.intro != blank -%}<div class="collector-trust-bar__intro rte reveal-fade-up reveal-delay-1" data-reveal="subtle">{{ section.settings.intro }}</div>{%- endif -%}

    <div class="collector-trust-bar reveal-fade-up reveal-delay-2" data-reveal>
      {%- for block in section.blocks -%}
        <article class="collector-trust-bar__item" {{ block.shopify_attributes }}>
          {%- if block.settings.icon != blank -%}
            <div class="collector-trust-bar__icon">{{ block.settings.icon | image_url: width: 96 | image_tag: loading: 'lazy', alt: block.settings.heading }}</div>
          {%- endif -%}
          <h3>{{ block.settings.heading | escape }}</h3>
          <p>{{ block.settings.text | escape }}</p>
          {%- if block.settings.cta_label != blank and block.settings.cta_link != blank -%}<p class="collector-trust-bar__cta"><a class="btn-premium" href="{{ block.settings.cta_link }}">{{ block.settings.cta_label | escape }}</a></p>{%- endif -%}
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #CollectorTrustBar-{{ section.id }} { padding-top: var(--ctb-pt); padding-bottom: var(--ctb-pb); background: var(--ctb-bg, var(--ds-color-bg, #050505)); }
  #CollectorTrustBar-{{ section.id }} .collector-trust-bar__title { text-align: left; color: var(--ctb-text, var(--ds-color-text-strong, #F4EFE6)); }
  #CollectorTrustBar-{{ section.id }} .collector-trust-bar__intro { max-width: 56ch; color: var(--ctb-muted, var(--ds-color-text-muted, #A7A29A)); margin-bottom: 1rem; }
  #CollectorTrustBar-{{ section.id }} .collector-trust-bar { display: grid; grid-template-columns: repeat(var(--ctb-cols), minmax(0, 1fr)); gap: 0.8rem; }
  #CollectorTrustBar-{{ section.id }} .collector-trust-bar__item { background: linear-gradient(180deg, var(--ds-color-surface-1, #17181B) 0%, var(--ds-color-surface-0, #101113) 100%); border: 1px solid var(--ctb-border, var(--ds-color-border, #2A2B2F)); border-radius: var(--ds-radius-md, 0.2rem); padding: 1rem; }
  #CollectorTrustBar-{{ section.id }} .collector-trust-bar__icon { margin-bottom: 0.5rem; }
  #CollectorTrustBar-{{ section.id }} .collector-trust-bar__icon img { width: 1.6rem; height: 1.6rem; object-fit: contain; }
  #CollectorTrustBar-{{ section.id }} .collector-trust-bar__item h3 { margin: 0 0 0.25rem; font-family: var(--ds-font-heading, var(--font-heading)); text-transform: uppercase; font-size: 0.9rem; color: var(--ctb-text, var(--ds-color-text-strong, #F4EFE6)); }
  #CollectorTrustBar-{{ section.id }} .collector-trust-bar__item p { margin: 0; font-size: 0.92rem; color: var(--ctb-muted, var(--ds-color-text-muted, #A7A29A)); }
  #CollectorTrustBar-{{ section.id }} .collector-trust-bar__cta { margin-top: 0.8rem; }
  @media (max-width: 989px) { #CollectorTrustBar-{{ section.id }} .collector-trust-bar { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 749px) { #CollectorTrustBar-{{ section.id }} .collector-trust-bar { grid-template-columns: 1fr; } }
</style>

{% schema %}
{
  "name": "Collector trust bar",
  "max_blocks": 8,
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Collector Trust Signals" },
    { "type": "richtext", "id": "intro", "label": "Intro text", "default": "<p>Clear standards, archival quality, and collector-safe delivery.</p>" },
    { "type": "select", "id": "columns_desktop", "label": "Desktop columns", "default": "4", "options": [{"value":"2","label":"2"},{"value":"3","label":"3"},{"value":"4","label":"4"}] },
    { "type": "color", "id": "background_color", "label": "Section background", "default": "#050505" },
    { "type": "color", "id": "text_color", "label": "Heading color", "default": "#F4EFE6" },
    { "type": "color", "id": "muted_text_color", "label": "Body color", "default": "#A7A29A" },
    { "type": "color", "id": "border_color", "label": "Border color", "default": "#2A2B2F" },
    { "type": "range", "id": "padding_top", "label": "Top spacing", "min": 0, "max": 180, "step": 4, "default": 40, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Bottom spacing", "min": 0, "max": 180, "step": 4, "default": 40, "unit": "px" }
  ],
  "blocks": [
    {
      "type": "trust",
      "name": "Trust item",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Icon" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Collector-safe packaging" },
        { "type": "text", "id": "text", "label": "Text", "default": "Built to protect each edition in transit." },
        { "type": "text", "id": "cta_label", "label": "CTA label" },
        { "type": "url", "id": "cta_link", "label": "CTA link" }
      ]
    }
  ],
  "presets": [{ "name": "Collector trust bar" }]
}
{% endschema %}
