<section id="LoreProcess-{{ section.id }}" class="section-shell" style="--lp-pt: {{ section.settings.padding_top }}px; --lp-pb: {{ section.settings.padding_bottom }}px; --lp-bg: {{ section.settings.background_color }}; --lp-text: {{ section.settings.text_color }}; --lp-muted: {{ section.settings.muted_text_color }}; --lp-border: {{ section.settings.border_color }};">
  <div class="page-width">
    <div class="lore-process-wrap reveal-fade-up" data-reveal="deep">
      {%- if section.settings.eyebrow != blank -%}<p class="label-kicker reveal-fade-up reveal-delay-1" data-reveal="subtle">{{ section.settings.eyebrow | escape }}</p>{%- endif -%}
      <h2 class="section-title lore-process__title reveal-fade-up reveal-delay-2" data-reveal>{{ section.settings.heading | escape }}</h2>
      {%- if section.settings.intro != blank -%}<div class="rte lore-process__intro reveal-fade-up reveal-delay-3" data-reveal="subtle">{{ section.settings.intro }}</div>{%- endif -%}
      <div class="lore-process-grid">
        {%- for block in section.blocks -%}
          <article class="value-card lore-process-grid__item reveal-fade-up" data-reveal {{ block.shopify_attributes }}>
            <p class="label-kicker">Step {{ forloop.index }}</p>
            <h3>{{ block.settings.heading | escape }}</h3>
            <div class="rte">{{ block.settings.text }}</div>
            {%- if block.settings.image != blank -%}<div class="lore-process-grid__image image-hover-scale image-hover-scale--soft">{{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '320, 480, 720, 960, 1200', sizes: '(min-width: 990px) 30vw, 100vw', alt: block.settings.heading }}</div>{%- endif -%}
          </article>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<style>
  #LoreProcess-{{ section.id }} { padding-top: var(--lp-pt); padding-bottom: var(--lp-pb); background: var(--lp-bg, var(--ds-color-bg, #050505)); }
  #LoreProcess-{{ section.id }} .lore-process-wrap { border: 1px solid var(--lp-border, var(--ds-color-border, #2A2B2F)); border-radius: var(--ds-radius-lg, 0.4rem); padding: clamp(1rem, 2.8vw, 2rem); background: linear-gradient(180deg, var(--ds-color-surface-1, #17181B) 0%, var(--ds-color-surface-0, #101113) 100%); }
  #LoreProcess-{{ section.id }} .lore-process__title { text-align: left; color: var(--lp-text, var(--ds-color-text-strong, #F4EFE6)); }
  #LoreProcess-{{ section.id }} .lore-process__intro { max-width: 58ch; margin-bottom: 1rem; color: var(--lp-muted, var(--ds-color-text-muted, #A7A29A)); }
  #LoreProcess-{{ section.id }} .lore-process-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 0.9rem; }
  #LoreProcess-{{ section.id }} .lore-process-grid__item h3 { margin: 0 0 0.4rem; font-family: var(--ds-font-heading, var(--font-heading)); text-transform: uppercase; color: var(--lp-text, var(--ds-color-text-strong, #F4EFE6)); }
  #LoreProcess-{{ section.id }} .lore-process-grid__item .rte { color: var(--lp-muted, var(--ds-color-text, #F4EFE6)); }
  #LoreProcess-{{ section.id }} .lore-process-grid__image { margin-top: 0.8rem; border: 1px solid var(--lp-border, var(--ds-color-border, #2A2B2F)); border-radius: var(--ds-radius-md, 0.2rem); overflow: hidden; }
  #LoreProcess-{{ section.id }} .lore-process-grid__image img { width: 100%; height: auto; }
  @media (max-width: 989px) { #LoreProcess-{{ section.id }} .lore-process-grid { grid-template-columns: 1fr; } }
</style>

{% schema %}
{
  "name": "Lore process",
  "max_blocks": 8,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Craft" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Print Process" },
    { "type": "richtext", "id": "intro", "label": "Intro text", "default": "<p>From source curation to collector-safe packaging.</p>" },
    { "type": "color", "id": "background_color", "label": "Section background", "default": "#050505" },
    { "type": "color", "id": "text_color", "label": "Heading color", "default": "#F4EFE6" },
    { "type": "color", "id": "muted_text_color", "label": "Body color", "default": "#A7A29A" },
    { "type": "color", "id": "border_color", "label": "Border color", "default": "#2A2B2F" },
    { "type": "range", "id": "padding_top", "label": "Top spacing", "min": 0, "max": 180, "step": 4, "default": 56, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Bottom spacing", "min": 0, "max": 180, "step": 4, "default": 56, "unit": "px" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Curation" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Works are selected for visual tension, atmosphere, and collector appeal.</p>" },
        { "type": "image_picker", "id": "image", "label": "Optional image" }
      ]
    }
  ],
  "presets": [{ "name": "Lore process" }]
}
{% endschema %}
