<section class="section-shell">
  <div class="page-width">
    <h2 class="section-title">{{ section.settings.heading | escape }}</h2>
    <div class="category-grid">
      {%- for block in section.blocks -%}
        <article class="category-card" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {% render 'responsive-image', image: block.settings.image, alt: block.settings.heading, width: 1000 %}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'category-card__placeholder' }}
          {%- endif -%}
          <div class="category-card__overlay">
            <h3>{{ block.settings.heading | escape }}</h3>
            <p>{{ block.settings.text | escape }}</p>
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .category-card__placeholder {
    width: 100%;
    height: 100%;
    min-height: 14rem;
    display: block;
    background: var(--ds-color-surface-1, #17181B);
    color: var(--ds-color-text-muted, #A7A29A);
  }
</style>

{% schema %}
{
  "name": "Collage editorial",
  "max_blocks": 8,
  "settings": [{ "type": "text", "id": "heading", "label": "Heading", "default": "Editorial collage" }],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Studio setup" },
        { "type": "text", "id": "text", "label": "Text", "default": "Community-inspired spaces." }
      ]
    }
  ],
  "presets": [{ "name": "Collage editorial" }]
}
{% endschema %}
