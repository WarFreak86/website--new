<section
  id="LoreSplit-{{ section.id }}"
  class="section-shell"
  style="
    --ls-pt: {{ section.settings.padding_top }}px;
    --ls-pb: {{ section.settings.padding_bottom }}px;
    --ls-bg: {{ section.settings.background_color }};
    --ls-text: {{ section.settings.text_color }};
    --ls-muted: {{ section.settings.muted_text_color }};
    --ls-border: {{ section.settings.border_color }};
  "
>
  <div class="page-width lore-split lore-split--{{ section.settings.image_position }} lore-split--{{ section.settings.layout_style }} reveal-fade-up" data-reveal="deep">
    <div class="lore-split__media image-hover-scale reveal-fade-up reveal-delay-1" data-reveal="subtle">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1800 | image_tag: loading: 'lazy', widths: '720, 960, 1280, 1600, 1800', sizes: '(min-width: 990px) 44vw, 100vw', alt: section.settings.heading }}
      {%- endif -%}
    </div>
    <div class="lore-split__content reveal-fade-up reveal-delay-2" data-reveal>
      {%- if section.settings.eyebrow != blank -%}<p class="label-kicker">{{ section.settings.eyebrow | escape }}</p>{%- endif -%}
      <h2 class="section-title lore-split__title">{{ section.settings.heading | escape }}</h2>
      <div class="rte lore-split__text">{{ section.settings.text }}</div>
      {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}<p><a class="btn-premium" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label | escape }}</a></p>{%- endif -%}
    </div>
  </div>
</section>

<style>
  #LoreSplit-{{ section.id }} { padding-top: var(--ls-pt); padding-bottom: var(--ls-pb); background: var(--ls-bg, var(--ds-color-bg, #050505)); }
  #LoreSplit-{{ section.id }} .lore-split { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(1rem, 2.4vw, 2.2rem); align-items: stretch; }
  #LoreSplit-{{ section.id }} .lore-split--feature { grid-template-columns: 1.2fr 0.8fr; }
  #LoreSplit-{{ section.id }} .lore-split--balanced { grid-template-columns: 1fr 1fr; }
  #LoreSplit-{{ section.id }} .lore-split--right .lore-split__media { order: 2; }
  #LoreSplit-{{ section.id }} .lore-split__media { border: 1px solid var(--ls-border, var(--ds-color-border, #2A2B2F)); background: var(--ds-color-surface-1, #17181B); min-height: 18rem; border-radius: var(--ds-radius-md, 0.2rem); overflow: hidden; }
  #LoreSplit-{{ section.id }} .lore-split__media img { width: 100%; height: 100%; object-fit: cover; }
  #LoreSplit-{{ section.id }} .lore-split__content { border: 1px solid var(--ls-border, var(--ds-color-border, #2A2B2F)); border-radius: var(--ds-radius-md, 0.2rem); padding: clamp(1rem, 2.6vw, 2rem); background: linear-gradient(180deg, var(--ds-color-surface-1, #17181B) 0%, var(--ds-color-surface-0, #101113) 100%); }
  #LoreSplit-{{ section.id }} .lore-split__title { text-align: left; color: var(--ls-text, var(--ds-color-text-strong, #F4EFE6)); }
  #LoreSplit-{{ section.id }} .lore-split__text { color: var(--ls-muted, var(--ds-color-text, #F4EFE6)); }
  @media (max-width: 989px) {
    #LoreSplit-{{ section.id }} .lore-split,
    #LoreSplit-{{ section.id }} .lore-split--right,
    #LoreSplit-{{ section.id }} .lore-split--feature,
    #LoreSplit-{{ section.id }} .lore-split--balanced { grid-template-columns: 1fr; }
    #LoreSplit-{{ section.id }} .lore-split--right .lore-split__media { order: 0; }
  }
</style>

{% schema %}
{
  "name": "Lore editorial split",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Archive Entry" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Lab" },
    { "type": "richtext", "id": "text", "label": "Body text", "default": "<p>Inside the process, references, and tensions that shape each release.</p>" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "select", "id": "image_position", "label": "Image position", "default": "left", "options": [{"value":"left","label":"Left"},{"value":"right","label":"Right"}] },
    { "type": "select", "id": "layout_style", "label": "Layout style", "default": "feature", "options": [{"value":"feature","label":"Feature"},{"value":"balanced","label":"Balanced"}] },
    { "type": "text", "id": "cta_label", "label": "CTA label" },
    { "type": "url", "id": "cta_link", "label": "CTA link" },
    { "type": "color", "id": "background_color", "label": "Section background", "default": "#050505" },
    { "type": "color", "id": "text_color", "label": "Heading color", "default": "#F4EFE6" },
    { "type": "color", "id": "muted_text_color", "label": "Body color", "default": "#A7A29A" },
    { "type": "color", "id": "border_color", "label": "Border color", "default": "#2A2B2F" },
    { "type": "range", "id": "padding_top", "label": "Top spacing", "min": 0, "max": 180, "step": 4, "default": 56, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Bottom spacing", "min": 0, "max": 180, "step": 4, "default": 56, "unit": "px" }
  ],
  "presets": [{ "name": "Lore editorial split" }]
}
{% endschema %}
