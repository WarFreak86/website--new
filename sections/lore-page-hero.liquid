<section
  id="LorePageHero-{{ section.id }}"
  class="section-shell lore-page-hero"
  style="
    --lph-pt: {{ section.settings.padding_top }}px;
    --lph-pb: {{ section.settings.padding_bottom }}px;
    --lph-overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --lph-bg: {{ section.settings.background_color }};
    --lph-text: {{ section.settings.text_color }};
    --lph-muted: {{ section.settings.muted_text_color }};
    --lph-border: {{ section.settings.border_color }};
    --lph-align: {{ section.settings.text_alignment }};
  "
>
  <div class="page-width">
    <div class="lore-hero__frame reveal-fade-up" data-reveal="deep">
      {%- if section.settings.image != blank -%}
        <div class="lore-hero__media image-hover-scale image-hover-scale--soft">
          {{ section.settings.image | image_url: width: 2400 | image_tag: loading: 'eager', widths: '750, 1100, 1500, 2000, 2400', sizes: '100vw', alt: section.settings.heading }}
        </div>
      {%- endif -%}

      <div class="lore-hero__overlay" aria-hidden="true"></div>

      <div class="lore-hero__content lore-hero__content--{{ section.settings.text_alignment }}">
        {%- if section.settings.eyebrow != blank -%}<p class="label-kicker reveal-fade-up reveal-delay-1" data-reveal="subtle">{{ section.settings.eyebrow | escape }}</p>{%- endif -%}
        <h1 class="lore-hero__title reveal-fade-up reveal-delay-2" data-reveal>{{ section.settings.heading | escape }}</h1>
        {%- if section.settings.text != blank -%}<div class="rte lore-hero__text reveal-fade-up reveal-delay-3" data-reveal="subtle">{{ section.settings.text }}</div>{%- endif -%}
        {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
          <p class="lore-hero__actions reveal-fade-up reveal-delay-4" data-reveal="subtle"><a class="btn-premium" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label | escape }}</a></p>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
  #LorePageHero-{{ section.id }} { padding-top: var(--lph-pt); padding-bottom: var(--lph-pb); background: var(--lph-bg, var(--ds-color-bg, #050505)); }
  #LorePageHero-{{ section.id }} .lore-hero__frame { position: relative; min-height: clamp(22rem, 54vw, 44rem); border: 1px solid var(--lph-border, var(--ds-color-border, #2A2B2F)); overflow: hidden; border-radius: var(--ds-radius-lg, 0.4rem); background: var(--ds-color-surface-0, #101113); }
  #LorePageHero-{{ section.id }} .lore-hero__media,
  #LorePageHero-{{ section.id }} .lore-hero__media img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  #LorePageHero-{{ section.id }} .lore-hero__overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(5, 5, 5, calc(var(--lph-overlay) * 0.55)) 0%, rgba(5, 5, 5, var(--lph-overlay)) 100%); z-index: 1; }
  #LorePageHero-{{ section.id }} .lore-hero__content { position: relative; z-index: 2; padding: clamp(1.2rem, 5vw, 4rem); max-width: 52rem; color: var(--lph-text, var(--ds-color-text-strong, #F4EFE6)); }
  #LorePageHero-{{ section.id }} .lore-hero__content--center { text-align: center; margin-inline: auto; }
  #LorePageHero-{{ section.id }} .lore-hero__content--right { text-align: right; margin-left: auto; }
  #LorePageHero-{{ section.id }} .lore-hero__title { margin: 0; font-family: var(--ds-font-heading, var(--font-heading)); font-size: clamp(2rem, 7vw, 5.2rem); line-height: 0.92; text-transform: uppercase; letter-spacing: -0.02em; }
  #LorePageHero-{{ section.id }} .lore-hero__text { margin-top: 1rem; max-width: 42ch; color: var(--lph-muted, var(--ds-color-text, #F4EFE6)); }
  #LorePageHero-{{ section.id }} .lore-hero__content--center .lore-hero__text { margin-inline: auto; }
  #LorePageHero-{{ section.id }} .lore-hero__content--right .lore-hero__text { margin-left: auto; }
  #LorePageHero-{{ section.id }} .lore-hero__actions { margin-top: 1.2rem; }
</style>

{% schema %}
{
  "name": "Lore page hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Render-Lab Lore" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Manifesto" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Collector-grade stories from the archive.</p>" },
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "text", "id": "cta_label", "label": "CTA label" },
    { "type": "url", "id": "cta_link", "label": "CTA link" },
    { "type": "select", "id": "text_alignment", "label": "Text alignment", "default": "left", "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"},{"value":"right","label":"Right"}] },
    { "type": "color", "id": "background_color", "label": "Section background", "default": "#050505" },
    { "type": "color", "id": "text_color", "label": "Heading color", "default": "#F4EFE6" },
    { "type": "color", "id": "muted_text_color", "label": "Body color", "default": "#A7A29A" },
    { "type": "color", "id": "border_color", "label": "Border color", "default": "#2A2B2F" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 90, "step": 5, "default": 45, "unit": "%" },
    { "type": "range", "id": "padding_top", "label": "Top spacing", "min": 0, "max": 180, "step": 4, "default": 56, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Bottom spacing", "min": 0, "max": 180, "step": 4, "default": 56, "unit": "px" }
  ],
  "presets": [{ "name": "Lore page hero" }]
}
{% endschema %}
