<section id="LoreTimeline-{{ section.id }}" class="section-shell" style="--lt-pt: {{ section.settings.padding_top }}px; --lt-pb: {{ section.settings.padding_bottom }}px; --lt-bg: {{ section.settings.background_color }}; --lt-text: {{ section.settings.text_color }}; --lt-muted: {{ section.settings.muted_text_color }}; --lt-border: {{ section.settings.border_color }};">
  <div class="page-width">
    <div class="lore-timeline-wrap reveal-fade-up" data-reveal="deep">
      {%- if section.settings.eyebrow != blank -%}<p class="label-kicker reveal-fade-up reveal-delay-1" data-reveal="subtle">{{ section.settings.eyebrow | escape }}</p>{%- endif -%}
      <h2 class="section-title lore-timeline__title reveal-fade-up reveal-delay-2" data-reveal>{{ section.settings.heading | escape }}</h2>
      <div class="lore-timeline">
        {%- for block in section.blocks -%}
          <article class="value-card lore-timeline__item reveal-fade-up" data-reveal {{ block.shopify_attributes }}>
            <p class="label-kicker">{{ block.settings.label | escape }}</p>
            <h3>{{ block.settings.heading | escape }}</h3>
            <div class="rte">{{ block.settings.text }}</div>
            {%- if block.settings.cta_label != blank and block.settings.cta_link != blank -%}<p><a class="btn-premium" href="{{ block.settings.cta_link }}">{{ block.settings.cta_label | escape }}</a></p>{%- endif -%}
          </article>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<style>
  #LoreTimeline-{{ section.id }} { padding-top: var(--lt-pt); padding-bottom: var(--lt-pb); background: var(--lt-bg, var(--ds-color-bg, #050505)); }
  #LoreTimeline-{{ section.id }} .lore-timeline-wrap { border: 1px solid var(--lt-border, var(--ds-color-border, #2A2B2F)); border-radius: var(--ds-radius-lg, 0.4rem); padding: clamp(1rem, 2.8vw, 2rem); background: linear-gradient(180deg, var(--ds-color-surface-1, #17181B) 0%, var(--ds-color-surface-0, #101113) 100%); }
  #LoreTimeline-{{ section.id }} .lore-timeline__title { text-align: left; color: var(--lt-text, var(--ds-color-text-strong, #F4EFE6)); }
  #LoreTimeline-{{ section.id }} .lore-timeline { display: grid; gap: 0.9rem; }
  #LoreTimeline-{{ section.id }} .lore-timeline__item h3 { margin: 0 0 0.4rem; font-family: var(--ds-font-heading, var(--font-heading)); text-transform: uppercase; color: var(--lt-text, var(--ds-color-text-strong, #F4EFE6)); }
  #LoreTimeline-{{ section.id }} .lore-timeline__item .rte { color: var(--lt-muted, var(--ds-color-text, #F4EFE6)); }
</style>

{% schema %}
{
  "name": "Lore timeline",
  "max_blocks": 12,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Archive" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Archive Timeline" },
    { "type": "color", "id": "background_color", "label": "Section background", "default": "#050505" },
    { "type": "color", "id": "text_color", "label": "Heading color", "default": "#F4EFE6" },
    { "type": "color", "id": "muted_text_color", "label": "Body color", "default": "#A7A29A" },
    { "type": "color", "id": "border_color", "label": "Border color", "default": "#2A2B2F" },
    { "type": "range", "id": "padding_top", "label": "Top spacing", "min": 0, "max": 180, "step": 4, "default": 56, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Bottom spacing", "min": 0, "max": 180, "step": 4, "default": 56, "unit": "px" }
  ],
  "blocks": [
    {
      "type": "entry",
      "name": "Entry",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Release 01" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Origin" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>The first archive launch established our visual DNA.</p>" },
        { "type": "text", "id": "cta_label", "label": "CTA label" },
        { "type": "url", "id": "cta_link", "label": "CTA link" }
      ]
    }
  ],
  "presets": [{ "name": "Lore timeline" }]
}
{% endschema %}
