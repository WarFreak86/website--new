<section class="section-shell">
  <div class="page-width">
    <h2 class="section-title">{{ section.settings.heading | escape }}</h2>
    <div class="category-grid">
      {%- for block in section.blocks -%}
        {%- assign c = collections[block.settings.collection] -%}
        <article class="category-card" {{ block.shopify_attributes }}>
          {% render 'responsive-image', image: c.featured_image, alt: c.title, width: 1000 %}
          <div class="category-card__overlay">
            <h3>{{ c.title }}</h3>
            <a class="btn btn-primary" href="{{ c.url }}">Shop</a>
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection list",
  "max_blocks": 12,
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by collection" }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [{ "type": "collection", "id": "collection", "label": "Collection" }]
    }
  ],
  "presets": [{ "name": "Collection list" }]
}
{% endschema %}
